{
  "name": "medical-transcription-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "port:8000": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\\\scripts\\\\port-info.ps1 8000",
    "predev": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\\\scripts\\\\kill-port.ps1 8000",
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": ".\\\\.venv\\\\Scripts\\\\python -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "prestart": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\\\scripts\\\\kill-port.ps1 8000",
    "start": "npm run build && .\\\\.venv\\\\Scripts\\\\python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "vite": "^8.0.13"
  }
}
